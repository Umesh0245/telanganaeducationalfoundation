---
import MainLayout from '../layouts/MainLayout.astro';
import { impactStats, programmes, campaigns, accreditations, foundationGallery } from '../data/site';
---

<MainLayout
  title="Telangana Educational Foundation"
  description="Telangana Educational Foundation advances inclusive development through education, healthcare, women empowerment and livelihood."
  activePath="/"
>
  <section class="section hero" data-reveal>
    <article class="card hero-copy" data-pulse>
      <p class="hero-kicker">Established For Lasting Change</p>
      <h1>Building Telangana's next generation through education, health and dignity.</h1>
      <p>
        Inspired by successful social development models, Telangana Educational Foundation creates integrated, measurable
        and community-driven change through learning, preventive healthcare, women empowerment and youth livelihood
        interventions.
      </p>
      <div class="pill-row">
        <a href="/donate">Donate Now</a>
        <a href="/programmes">Explore Programmes</a>
      </div>
    </article>

    <article class="card hero-visual" data-pulse>
      <!-- Main foundation image -->
      <div class="hero-mosaic-main">
        <img
          src="https://upload.wikimedia.org/wikipedia/commons/0/07/Teacher_explaining_students_in_Greenwood_High_School.jpg"
          alt="Teacher with students in a Telangana classroom learning session"
          onerror="this.onerror=null;this.src='https://upload.wikimedia.org/wikipedia/commons/f/f3/Playing_students_yellanki_high_school.jpg';"
          loading="eager"
          class="hero-mosaic-img"
        />
        <div class="hero-mosaic-overlay"></div>
        <!-- Logo badge -->
        <div class="hero-logo-badge">
          <img src="/tef-logo.jpeg" alt="Telangana Educational Foundation" class="hero-logo-small" />
        </div>
        <p class="hero-mosaic-tag">Transforming Lives Across Telangana</p>
      </div>

      <!-- Bottom row: two supporting images + centre stat -->
      <div class="hero-mosaic-row">
        <div class="hero-mosaic-thumb">
          <img
            src="https://upload.wikimedia.org/wikipedia/commons/f/f3/Playing_students_yellanki_high_school.jpg"
            alt="Children playing and learning at Yellanki high school"
            onerror="this.onerror=null;this.src='https://upload.wikimedia.org/wikipedia/commons/5/5d/Children_School_in_Duppelli.jpg';"
            loading="lazy"
          />
        </div>
        <div class="hero-mosaic-stat">
          <span class="hero-stat-num">12,000+</span>
          <span class="hero-stat-label">Lives Impacted</span>
        </div>
        <div class="hero-mosaic-thumb">
          <img
            src="https://upload.wikimedia.org/wikipedia/commons/3/3c/Childrens_day_group_photo.jpg"
            alt="Children group photo from a Telangana school event"
            onerror="this.onerror=null;this.src='https://upload.wikimedia.org/wikipedia/commons/0/05/High_school_yellanki.jpg';"
            loading="lazy"
          />
        </div>
      </div>

      <div class="hero-float">
        <h3>Impact Lens</h3>
        <p>Transparent action and district-level accountability.</p>
      </div>
    </article>
  </section>

  <section class="section" data-reveal>
    <h2>Our Impact</h2>
    <div class="grid">
      {
        impactStats.map((item) => (
          <article class="card" data-pulse>
            <h3>{item.value}</h3>
            <p>{item.label}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section" data-reveal>
    <h2>Our Programmes</h2>
    <div class="grid">
      {
        programmes.map((program, idx) => (
          <article class="card" data-pulse>
            <span class="badge">{`0${idx + 1}`}</span>
            <h3>{program.title}</h3>
            <p>{program.summary}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section" data-reveal>
    <h2>Field Moments</h2>
    <div class="image-grid">
      {
        foundationGallery.map((item) => (
          <article class="image-card" data-pulse>
            <img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
            <div class="image-caption">
              <h3>{item.title}</h3>
              <p>{item.caption}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section" data-reveal>
    <h2>Support A Cause</h2>
    <div class="grid">
      {
        campaigns.map((campaign, idx) => (
          <article class="card" data-pulse>
            <span class="badge">{`0${idx + 1}`}</span>
            <h3>{campaign.name}</h3>
            <p>{campaign.copy}</p>
            <div class="pill-row">
              <a href="/donate">Know More</a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section" data-reveal>
    <h2>Empanelment And Accreditations</h2>
    <div class="grid">
      {
        accreditations.map((item) => (
          <article class="card" data-pulse>
            <p>{item}</p>
          </article>
        ))
      }
    </div>
  </section>
</MainLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 0.9rem;
    min-height: 72vh;
  }

  .hero-copy {
    display: grid;
    align-content: center;
    gap: 1rem;
  }

  .hero-kicker {
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0f6e9b;
    font-weight: 600;
  }

  .hero h1 {
    line-height: 1;
  }

  .hero-visual {
    min-height: 480px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: 0;
    gap: 0;
  }

  /* ── Main image ───────────────────────────────────── */
  .hero-mosaic-main {
    flex: 1.5;
    position: relative;
    overflow: hidden;
    min-height: 0;
  }

  .hero-mosaic-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
  }

  .hero-mosaic-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(8, 30, 50, 0.08) 30%, rgba(8, 30, 50, 0.55) 100%);
    pointer-events: none;
  }

  /* TEF logo badge, top-left */
  .hero-logo-badge {
    position: absolute;
    top: 0.9rem;
    left: 0.9rem;
    z-index: 3;
    padding: 0.35rem 0.45rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.93);
    border: 1px solid rgba(114, 186, 232, 0.45);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  .hero-logo-small {
    display: block;
    width: 54px;
    height: 54px;
    object-fit: contain;
  }

  /* Tagline on main image */
  .hero-mosaic-tag {
    position: absolute;
    bottom: 0.85rem;
    left: 0.9rem;
    z-index: 3;
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #ffffff;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
  }

  /* ── Bottom row ───────────────────────────────────── */
  .hero-mosaic-row {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 3px;
    background: #0d4a6b;
  }

  .hero-mosaic-thumb {
    overflow: hidden;
  }

  .hero-mosaic-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
    transition: transform 0.5s ease;
  }

  .hero-mosaic-thumb:hover img {
    transform: scale(1.06);
  }

  /* Centre stat block */
  .hero-mosaic-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.1rem;
    background: linear-gradient(145deg, #0f6e9b, #0a4270);
    color: #ffffff;
    min-width: 108px;
    gap: 0.15rem;
  }

  .hero-stat-num {
    font-size: 1.65rem;
    font-weight: 800;
    font-family: 'Barlow Condensed', sans-serif;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .hero-stat-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.85;
    text-align: center;
  }

  .hero-float {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    max-width: 220px;
    padding: 0.8rem;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(117, 190, 236, 0.35);
  }

  .hero-float h3,
  .hero-float p {
    margin: 0;
  }

  .hero-float p {
    margin-top: 0.35rem;
    color: var(--text-muted);
  }

  @media (max-width: 1024px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-visual,
    [data-hero-canvas] {
      min-height: 420px;
    }
  }
</style>
