---
import MainLayout from '../layouts/MainLayout.astro';
import { impactStats, programmes, campaigns, accreditations, foundationGallery } from '../data/site';
---

<MainLayout
  title="Telangana Educational Foundation"
  description="Telangana Educational Foundation advances inclusive development through education, healthcare, women empowerment and livelihood."
  activePath="/"
>
  <section class="section landing-intro" data-reveal>
    <div class="landing-intro-topbar">
      <p class="landing-intro-title">
        <span>Merit Scholarship Program</span>
        <strong>Admissions Window Open</strong>
      </p>
      <div class="landing-intro-actions">
        <a class="intro-donate" href="/donate">Donate Now</a>
        <span class="intro-menu" aria-hidden="true">☰</span>
      </div>
    </div>

    <article class="landing-intro-hero">
      <div class="landing-intro-quote">
        <span class="intro-quote-kicker">Merit Scholarship 2026</span>
        <h1>Bringing Smiles Through Education & Empowerment</h1>
        <div class="intro-quote-body">
          <p>
            Telangana Educational Foundation empowers students from Telangana with merit-based scholarship access,
            transparent selection and family-focused academic continuity support.
          </p>
          <p class="intro-quote-highlight">
            1,000 qualified students can receive scholarship support up to Rs 4,50,000 for higher education pathways.
          </p>
          <ul class="intro-quote-points">
            <li>Clear process from offline college test to online interview.</li>
            <li>Merit, documentation and eligibility based final selection.</li>
            <li>Support aimed at real progression into professional courses.</li>
          </ul>
        </div>
        <div class="landing-intro-cta-row">
          <a class="intro-btn intro-btn-secondary" href="/programmes">Know More</a>
          <a class="intro-btn intro-btn-primary" href="/donate">Support A Student</a>
        </div>
      </div>

      <div class="landing-intro-image-wrap">
        <img
          src="https://upload.wikimedia.org/wikipedia/commons/3/3e/Twin_sisters_wearing_school_uniform_in_Si_Phan_Don.jpg"
          alt="School children in colorful uniforms"
          loading="eager"
        />
        <p class="landing-intro-image-tag">Telangana Kids, Brighter Futures</p>
      </div>
    </article>
  </section>

  <section class="section landing-scholarship" data-reveal>
    <div class="landing-scholarship-top">
      <article class="card landing-scholarship-copy" data-pulse>
        <span class="scholarship-chip">Merit Scholarship Program 2026</span>
        <h1>Empowering Telangana Students Through Higher-Education Scholarships</h1>
        <p class="lead">
          TEF scholarship initiative supports deserving intermediate passing students with structured financial
          assistance, transparent selection and academic continuity support.
        </p>
        <p class="hero-scholarship-note">
          For <strong>1,000 students</strong>, scholarship support is available up to <strong>Rs 4,50,000</strong>
          based on merit and eligibility.
        </p>
        <div class="pill-row">
          <a href="/donate">Support This Scholarship</a>
          <a href="/programmes">Eligibility & Programmes</a>
        </div>
      </article>

      <article class="card landing-flyer-card" data-pulse>
        <img
          class="landing-flyer"
          src="https://upload.wikimedia.org/wikipedia/commons/8/8d/Jyothi_engineering_college_vettikkattiri_students.jpg"
          alt="Indian students preparing for engineering education"
          loading="eager"
        />
        <p class="landing-image-note">Indian students preparing for engineering and technical higher education.</p>
      </article>
    </div>

    <article class="card landing-details" data-pulse>
      <h3>Scholarship Details At A Glance</h3>
      <p>
        The scholarship flow is presented as a fixed four-step process for students and families.
      </p>
      <div class="scholarship-study-grid" aria-label="Students studying through scholarship support">
        <article class="study-image-card">
          <img
            src="https://upload.wikimedia.org/wikipedia/commons/8/8e/Students_at_SRMS_CET_Unnao.jpg"
            alt="Indian students in a college learning environment"
            loading="lazy"
          />
          <p>Intermediate to engineering transition support</p>
        </article>
        <article class="study-image-card">
          <img
            src="https://upload.wikimedia.org/wikipedia/commons/9/9b/PCoE_students_at_AICTE_Regional_Office_in_Mumbai.jpg"
            alt="Indian students engaging in technical education orientation"
            loading="lazy"
          />
          <p>Career and engineering guidance exposure</p>
        </article>
        <article class="study-image-card">
          <img
            src="https://upload.wikimedia.org/wikipedia/commons/c/c3/M._Venkaiah_Naidu_interacting_with_the_Students_after_inaugurating_the_newly_constructed_Lecture_Hall-cum-Laboratory_Complex%2C_at_the_Andhra_University_College_of_Engineering_for_Women%2C_in_Visakhapatnam%2C_Andhra_Pradesh.jpg"
            alt="Indian women engineering students in a higher education setting"
            loading="lazy"
          />
          <p>Women students in engineering pathways</p>
        </article>
      </div>
      <div class="landing-stat-row">
        <article class="landing-stat-card">
          <p class="stat-kicker">Total Intake</p>
          <h3>1,000 Students</h3>
          <p>Selected through fair screening and documented eligibility checks.</p>
        </article>
        <article class="landing-stat-card">
          <p class="stat-kicker">Scholarship Value</p>
          <h3>Up To Rs 4,50,000</h3>
          <p>Financial support for eligible intermediate passing candidates.</p>
        </article>
        <article class="landing-stat-card">
          <p class="stat-kicker">Required Documents</p>
          <h3>ID + Academics + Admission</h3>
          <p>ID proof, academic records and college admission proof are required.</p>
        </article>
      </div>
      <div class="scholarship-process" aria-label="Scholarship process steps">
        <span><strong>1</strong>Take Offline Test In Your College</span>
        <span><strong>2</strong>Qualified Students Register For Online Test (Rs 900)</span>
        <span><strong>3</strong>Take Online Test And Online Interview</span>
        <span><strong>4</strong>1,000 Qualified Students Can Get Rs 4,50,000 Scholarship</span>
      </div>
    </article>
  </section>

  <section class="section hero" data-reveal>
    <article class="card hero-copy" data-pulse>
      <p class="hero-kicker">Established For Lasting Change</p>
      <h1>Building Telangana's next generation through education, health and dignity.</h1>
      <p>
        Inspired by successful social development models, Telangana Educational Foundation creates integrated, measurable
        and community-driven change through learning, preventive healthcare, women empowerment and youth livelihood
        interventions.
      </p>
      <p class="hero-scholarship-note">
        Merit Scholarship 2026: Support for <strong>1,000 students</strong> with scholarship assistance up to
        <strong>Rs 4,50,000</strong> for eligible intermediate passing students.
      </p>
      <div class="pill-row">
        <a href="/donate">Donate Now</a>
        <a href="/programmes">Explore Programmes</a>
      </div>
    </article>

    <article class="card hero-visual" data-pulse>
      <!-- Main foundation image -->
      <div class="hero-mosaic-main">
        <img
          src="https://upload.wikimedia.org/wikipedia/commons/0/07/Teacher_explaining_students_in_Greenwood_High_School.jpg"
          alt="Teacher with students in a Telangana classroom learning session"
          loading="eager"
          class="hero-mosaic-img"
        />
        <div class="hero-mosaic-overlay"></div>
        <!-- Logo badge -->
        <div class="hero-logo-badge">
          <img src="/tef-logo-tight.png" alt="Telangana Educational Foundation" class="hero-logo-small" />
        </div>
        <p class="hero-mosaic-tag">Transforming Lives Across Telangana</p>
      </div>

      <!-- Bottom row: two supporting images + centre stat -->
      <div class="hero-mosaic-row">
        <div class="hero-mosaic-thumb">
          <img
            src="https://upload.wikimedia.org/wikipedia/commons/f/f3/Playing_students_yellanki_high_school.jpg"
            alt="Children playing and learning at Yellanki high school"
            loading="lazy"
          />
        </div>
        <div class="hero-mosaic-stat">
          <span class="hero-stat-num">12,000+</span>
          <span class="hero-stat-label">Lives Impacted</span>
        </div>
        <div class="hero-mosaic-thumb">
          <img
            src="https://upload.wikimedia.org/wikipedia/commons/3/3c/Childrens_day_group_photo.jpg"
            alt="Children group photo from a Telangana school event"
            loading="lazy"
          />
        </div>
      </div>

      <div class="hero-float">
        <h3>Impact Lens</h3>
        <p>Transparent action and district-level accountability.</p>
      </div>
    </article>
  </section>

  <section class="section" data-reveal>
    <h2>Our Impact</h2>
    <div class="grid">
      {
        impactStats.map((item) => (
          <article class="card" data-pulse>
            <h3>{item.value}</h3>
            <p>{item.label}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section" data-reveal>
    <h2>Our Programmes</h2>
    <div class="grid">
      {
        programmes.map((program, idx) => (
          <article class="card" data-pulse>
            <span class="badge">{`0${idx + 1}`}</span>
            <h3>{program.title}</h3>
            <p>{program.summary}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section" data-reveal>
    <h2>Field Moments</h2>
    <div class="image-grid">
      {
        foundationGallery.map((item) => (
          <article class="image-card" data-pulse>
            <img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
            <div class="image-caption">
              <h3>{item.title}</h3>
              <p>{item.caption}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section" data-reveal>
    <h2>Support A Cause</h2>
    <div class="grid">
      {
        campaigns.map((campaign, idx) => (
          <article class="card" data-pulse>
            <span class="badge">{`0${idx + 1}`}</span>
            <h3>{campaign.name}</h3>
            <p>{campaign.copy}</p>
            <div class="pill-row">
              <a href="/donate">Know More</a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section" data-reveal>
    <h2>Empanelment And Accreditations</h2>
    <div class="grid">
      {
        accreditations.map((item) => (
          <article class="card" data-pulse>
            <p>{item}</p>
          </article>
        ))
      }
    </div>
  </section>
</MainLayout>

<style>
  .landing-intro {
    display: grid;
    gap: clamp(0.45rem, 1vw, 0.8rem);
    padding: clamp(0.35rem, 0.8vw, 0.6rem);
    background: rgba(255, 255, 255, 0.9);
  }

  .landing-intro-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    padding: 0.45rem 0.6rem;
    border-radius: 14px;
    background: #ffffff;
    border: 1px solid rgba(120, 196, 150, 0.34);
  }

  .landing-intro-title {
    margin: 0;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.42rem;
    line-height: 1;
  }

  .landing-intro-title span {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #16435f;
    font-weight: 700;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 1px solid rgba(92, 171, 121, 0.34);
    border-radius: 999px;
    padding: 0.23rem 0.58rem;
    background: rgba(227, 248, 234, 0.86);
    white-space: nowrap;
  }

  .landing-intro-title strong {
    display: inline-flex;
    align-items: center;
    color: #2f6a4c;
    font-size: 0.73rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    white-space: nowrap;
    padding-left: 0.48rem;
    border-left: 1px solid rgba(109, 183, 135, 0.48);
  }

  .landing-intro-actions {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex-shrink: 0;
  }

  .intro-donate {
    border-radius: 10px;
    padding: 0.52rem 0.76rem;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #ffffff;
    background: linear-gradient(135deg, #5bb041, #4a9537);
  }

  .intro-menu {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    color: #193e59;
    font-size: 1.35rem;
    font-weight: 700;
    border: 1px solid rgba(115, 173, 207, 0.42);
    background: #ffffff;
  }

  .landing-intro-hero {
    min-height: 500px;
    display: grid;
    grid-template-columns: minmax(320px, 1fr) minmax(360px, 1.08fr);
    gap: clamp(0.3rem, 0.7vw, 0.5rem);
    border-radius: 18px;
    border: 1px solid rgba(84, 160, 104, 0.3);
    background: linear-gradient(150deg, rgba(223, 246, 232, 0.7), rgba(205, 236, 220, 0.68));
    padding: clamp(0.3rem, 0.65vw, 0.45rem);
  }

  .landing-intro-quote {
    display: grid;
    align-content: stretch;
    gap: 0.76rem;
    padding: clamp(0.88rem, 1.5vw, 1.35rem);
    border-radius: 16px;
    background: linear-gradient(165deg, rgba(255, 255, 255, 0.92), rgba(238, 250, 243, 0.9));
    border: 1px solid rgba(126, 197, 151, 0.34);
    height: 100%;
  }

  .intro-quote-kicker {
    margin: 0;
    width: fit-content;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem 0.72rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.73rem;
    color: #1f6b49;
    background: rgba(217, 247, 228, 0.88);
    border: 1px solid rgba(88, 173, 118, 0.38);
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }

  .landing-intro-quote h1 {
    margin: 0;
    color: #12384f;
    font-size: clamp(1.42rem, 2.45vw, 1.95rem);
    line-height: 1.03;
  }

  .intro-quote-body {
    display: grid;
    gap: 0.65rem;
  }

  .landing-intro-quote p {
    margin: 0;
    color: #244f66;
    max-width: 50ch;
  }

  .intro-quote-highlight {
    border-left: 4px solid #2f965f;
    background: rgba(223, 247, 232, 0.86);
    border-radius: 10px;
    padding: 0.55rem 0.65rem;
    color: #1f5d3f;
    font-weight: 600;
  }

  .intro-quote-points {
    margin: 0;
    padding-left: 1.05rem;
    color: #214d63;
    display: grid;
    gap: 0.32rem;
    line-height: 1.55;
  }

  .landing-intro-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.2rem;
    align-items: center;
  }

  .intro-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: auto;
    min-width: 138px;
    max-width: max-content;
    height: auto;
    min-height: 44px;
    aspect-ratio: auto;
    border-radius: 14px;
    padding: 0.6rem 1rem;
    font-weight: 700;
    font-size: 0.88rem;
    line-height: 1;
    white-space: nowrap;
    text-align: center;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, border-color 0.18s ease;
  }

  .intro-btn:hover {
    transform: translateY(-1px);
  }

  .intro-btn-secondary {
    color: #113f5d;
    background: linear-gradient(145deg, #ffffff, #effaf3);
    border: 1px solid rgba(82, 170, 114, 0.46);
    box-shadow: 0 7px 14px rgba(31, 112, 75, 0.14);
  }

  .intro-btn-primary {
    color: #ffffff;
    background: linear-gradient(135deg, #37ab70, #1f7b4d);
    border: 1px solid rgba(30, 118, 75, 0.55);
    box-shadow: 0 10px 18px rgba(30, 108, 72, 0.26);
  }

  .intro-btn-secondary:hover {
    background: linear-gradient(145deg, #ffffff, #e6f7ee);
    border-color: rgba(73, 162, 106, 0.58);
  }

  .intro-btn-primary:hover {
    background: linear-gradient(135deg, #3ab477, #216d48);
  }

  .landing-intro-image-wrap {
    position: relative;
    width: 100%;
    justify-self: stretch;
    height: 100%;
    aspect-ratio: 3 / 4;
    min-height: 470px;
    overflow: hidden;
    border-radius: 16px;
    border: 1px solid rgba(98, 174, 127, 0.3);
    box-shadow: 0 20px 35px rgba(26, 101, 69, 0.14);
  }

  .landing-intro-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transform: scale(1.015);
  }

  .landing-intro-image-tag {
    position: absolute;
    left: 0.75rem;
    bottom: 0.75rem;
    margin: 0;
    z-index: 2;
    padding: 0.3rem 0.55rem;
    border-radius: 999px;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #ffffff;
    background: rgba(10, 58, 86, 0.7);
    border: 1px solid rgba(146, 210, 245, 0.36);
    font-weight: 700;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 0.9rem;
    min-height: 72vh;
  }

  .hero-copy {
    display: grid;
    align-content: center;
    gap: 1rem;
  }

  .hero-kicker {
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0f6e9b;
    font-weight: 600;
  }

  .hero-scholarship-note {
    border-left: 4px solid #43a067;
    background: rgba(225, 246, 232, 0.7);
    border-radius: 10px;
    padding: 0.7rem 0.8rem;
    color: #1f4c35;
    font-weight: 500;
  }

  .hero h1 {
    line-height: 1;
  }

  .hero-visual {
    min-height: 480px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: 0;
    gap: 0;
  }

  /* ── Main image ───────────────────────────────────── */
  .hero-mosaic-main {
    flex: 1.5;
    position: relative;
    overflow: hidden;
    min-height: 0;
  }

  .hero-mosaic-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
  }

  .hero-mosaic-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(8, 30, 50, 0.08) 30%, rgba(8, 30, 50, 0.55) 100%);
    pointer-events: none;
  }

  /* TEF logo badge, top-left */
  .hero-logo-badge {
    position: absolute;
    top: 0.9rem;
    left: 0.9rem;
    z-index: 3;
    padding: 0;
    border-radius: 999px;
    background: transparent;
    border: none;
    box-shadow: 0 8px 22px rgba(11, 56, 82, 0.32);
    overflow: hidden;
  }

  .hero-logo-small {
    display: block;
    width: 58px;
    height: 58px;
    object-fit: cover;
    object-position: center;
    border-radius: 50%;
  }

  .landing-scholarship {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .landing-scholarship-top {
    display: grid;
    grid-template-columns: 1.03fr 0.97fr;
    gap: 1rem;
    align-items: stretch;
  }

  .landing-flyer-card,
  .landing-scholarship-copy {
    display: grid;
    gap: 0.9rem;
    align-content: start;
  }

  .landing-flyer-card {
    padding: 0.9rem;
  }

  .landing-flyer {
    width: 100%;
    height: 100%;
    max-height: 780px;
    object-fit: cover;
    border-radius: 16px;
    border: 1px solid rgba(84, 173, 113, 0.35);
    display: block;
  }

  .landing-image-note {
    margin: 0;
    font-size: 0.9rem;
    color: #2b6048;
    line-height: 1.5;
    font-weight: 600;
  }

  .scholarship-chip {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    padding: 0.38rem 0.78rem;
    border-radius: 999px;
    font-size: 0.76rem;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #1f5e40;
    background: rgba(206, 242, 216, 0.9);
    border: 1px solid rgba(74, 171, 108, 0.4);
    font-weight: 700;
  }

  .landing-scholarship-copy h1 {
    margin: 0;
    font-size: clamp(2rem, 2.8vw, 2.5rem);
    line-height: 1.02;
  }

  .landing-details {
    display: grid;
    gap: 0.85rem;
  }

  .landing-details h3 {
    font-size: clamp(1.55rem, 2.2vw, 2rem);
  }

  .scholarship-study-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .study-image-card {
    border: 1px solid rgba(101, 182, 128, 0.34);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.88);
    overflow: hidden;
  }

  .study-image-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .study-image-card p {
    margin: 0;
    padding: 0.5rem 0.6rem;
    font-size: 0.85rem;
    color: #24563f;
    font-weight: 600;
  }

  .landing-stat-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .landing-stat-card {
    border-radius: 14px;
    border: 1px solid rgba(96, 182, 125, 0.34);
    background: rgba(238, 251, 243, 0.85);
    padding: 0.7rem 0.8rem;
  }

  .landing-stat-card h3 {
    margin: 0.2rem 0 0;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    color: #165b40;
  }

  .landing-stat-card p {
    margin-top: 0.28rem;
    color: #2f5f47;
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .stat-kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    font-size: 0.7rem;
    color: #2d7a56;
    font-weight: 700;
  }

  .scholarship-process {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.55rem;
  }

  .scholarship-process span {
    border: 1px solid rgba(102, 186, 130, 0.35);
    border-radius: 12px;
    padding: 0.55rem 0.5rem;
    background: rgba(236, 250, 240, 0.95);
