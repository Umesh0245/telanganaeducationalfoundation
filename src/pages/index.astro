---
import MainLayout from '../layouts/MainLayout.astro';
import { impactStats, programmes, campaigns, accreditations, foundationGallery } from '../data/site';
---

<MainLayout
  title="Telangana Educational Foundation"
  description="Telangana Educational Foundation advances inclusive development through education, healthcare, women empowerment and livelihood."
  activePath="/"
>
  <section class="section hero" data-reveal>
    <article class="card hero-copy" data-pulse>
      <p class="hero-kicker">Established For Lasting Change</p>
      <h1>Building Telangana's next generation through education, health and dignity.</h1>
      <p>
        Inspired by successful social development models, Telangana Educational Foundation creates integrated, measurable
        and community-driven change through learning, preventive healthcare, women empowerment and youth livelihood
        interventions.
      </p>
      <p class="hero-scholarship-note">
        Merit Scholarship 2026: Support for <strong>1,000 students</strong> with scholarship assistance up to
        <strong>Rs 4,50,000</strong> for eligible intermediate passing students.
      </p>
      <div class="pill-row">
        <a href="/donate">Donate Now</a>
        <a href="/programmes">Explore Programmes</a>
      </div>
    </article>

    <article class="card hero-visual" data-pulse>
      <!-- Main foundation image -->
      <div class="hero-mosaic-main">
        <img
          src="https://upload.wikimedia.org/wikipedia/commons/0/07/Teacher_explaining_students_in_Greenwood_High_School.jpg"
          alt="Teacher with students in a Telangana classroom learning session"
          loading="eager"
          class="hero-mosaic-img"
        />
        <div class="hero-mosaic-overlay"></div>
        <!-- Logo badge -->
        <div class="hero-logo-badge">
          <img src="/tef-logo.jpeg" alt="Telangana Educational Foundation" class="hero-logo-small" />
        </div>
        <p class="hero-mosaic-tag">Transforming Lives Across Telangana</p>
      </div>

      <!-- Bottom row: two supporting images + centre stat -->
      <div class="hero-mosaic-row">
        <div class="hero-mosaic-thumb">
          <img
            src="https://upload.wikimedia.org/wikipedia/commons/f/f3/Playing_students_yellanki_high_school.jpg"
            alt="Children playing and learning at Yellanki high school"
            loading="lazy"
          />
        </div>
        <div class="hero-mosaic-stat">
          <span class="hero-stat-num">12,000+</span>
          <span class="hero-stat-label">Lives Impacted</span>
        </div>
        <div class="hero-mosaic-thumb">
          <img
            src="https://upload.wikimedia.org/wikipedia/commons/3/3c/Childrens_day_group_photo.jpg"
            alt="Children group photo from a Telangana school event"
            loading="lazy"
          />
        </div>
      </div>

      <div class="hero-float">
        <h3>Impact Lens</h3>
        <p>Transparent action and district-level accountability.</p>
      </div>
    </article>
  </section>

  <section class="section scholarship-focus" data-reveal>
    <article class="card scholarship-copy" data-pulse>
      <span class="scholarship-chip">Merit Scholarship Program 2026</span>
      <h2>Scholarship Support For 1,000 Students</h2>
      <p class="lead">
        TEF scholarship flow is now clearly structured for intermediate passing students who need financial support to
        continue higher education.
      </p>
      <ul class="number-list">
        <li>For 1,000 students in the 2026 scholarship intake.</li>
        <li>Up to Rs 4,50,000 scholarship support for eligible candidates.</li>
        <li>Target group: intermediate passing students from deserving backgrounds.</li>
      </ul>
      <div class="pill-row scholarship-pill-row">
        <span>Registration</span>
        <span>Online Test</span>
        <span>Document Review</span>
        <span>Selection</span>
      </div>
    </article>

    <article class="card scholarship-poster" data-pulse>
      <img
        class="poster-flyer"
        src="/scholarship-flyer.svg"
        alt="TEF Merit Scholarship Program 2026 flyer"
        loading="eager"
      />
      <div class="poster-head">
        <p class="poster-kicker">Telangana Educational Foundation</p>
        <h3>Scholarship Up To Rs 4,50,000</h3>
      </div>
      <div class="poster-grid">
        <div class="poster-block">
          <h4>Who Can Apply</h4>
          <p>Intermediate passing students seeking support for higher education.</p>
        </div>
        <div class="poster-block">
          <h4>Test Areas</h4>
          <p>General Knowledge, Logical Reasoning and Telangana awareness.</p>
        </div>
        <div class="poster-block">
          <h4>Required Documents</h4>
          <p>ID proof, academic certificates and college admission proof.</p>
        </div>
        <div class="poster-block poster-highlight">
          <h4>Main Focus</h4>
          <p>1,000 students with transparent, merit-based scholarship selection.</p>
        </div>
      </div>
    </article>
  </section>

  <section class="section" data-reveal>
    <h2>Our Impact</h2>
    <div class="grid">
      {
        impactStats.map((item) => (
          <article class="card" data-pulse>
            <h3>{item.value}</h3>
            <p>{item.label}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section" data-reveal>
    <h2>Our Programmes</h2>
    <div class="grid">
      {
        programmes.map((program, idx) => (
          <article class="card" data-pulse>
            <span class="badge">{`0${idx + 1}`}</span>
            <h3>{program.title}</h3>
            <p>{program.summary}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section" data-reveal>
    <h2>Field Moments</h2>
    <div class="image-grid">
      {
        foundationGallery.map((item) => (
          <article class="image-card" data-pulse>
            <img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
            <div class="image-caption">
              <h3>{item.title}</h3>
              <p>{item.caption}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section" data-reveal>
    <h2>Support A Cause</h2>
    <div class="grid">
      {
        campaigns.map((campaign, idx) => (
          <article class="card" data-pulse>
            <span class="badge">{`0${idx + 1}`}</span>
            <h3>{campaign.name}</h3>
            <p>{campaign.copy}</p>
            <div class="pill-row">
              <a href="/donate">Know More</a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section" data-reveal>
    <h2>Empanelment And Accreditations</h2>
    <div class="grid">
      {
        accreditations.map((item) => (
          <article class="card" data-pulse>
            <p>{item}</p>
          </article>
        ))
      }
    </div>
  </section>
</MainLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 0.9rem;
    min-height: 72vh;
  }

  .hero-copy {
    display: grid;
    align-content: center;
    gap: 1rem;
  }

  .hero-kicker {
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0f6e9b;
    font-weight: 600;
  }

  .hero-scholarship-note {
    border-left: 4px solid #43a067;
    background: rgba(225, 246, 232, 0.7);
    border-radius: 10px;
    padding: 0.7rem 0.8rem;
    color: #1f4c35;
    font-weight: 500;
  }

  .hero h1 {
    line-height: 1;
  }

  .hero-visual {
    min-height: 480px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: 0;
    gap: 0;
  }

  /* ── Main image ───────────────────────────────────── */
  .hero-mosaic-main {
    flex: 1.5;
    position: relative;
    overflow: hidden;
    min-height: 0;
  }

  .hero-mosaic-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
  }

  .hero-mosaic-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(8, 30, 50, 0.08) 30%, rgba(8, 30, 50, 0.55) 100%);
    pointer-events: none;
  }

  /* TEF logo badge, top-left */
  .hero-logo-badge {
    position: absolute;
    top: 0.9rem;
    left: 0.9rem;
    z-index: 3;
    padding: 0.35rem 0.45rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.93);
    border: 1px solid rgba(114, 186, 232, 0.45);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  .hero-logo-small {
    display: block;
    width: 54px;
    height: 54px;
    object-fit: cover;
    border-radius: 50%;
  }

  .scholarship-focus {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 0.9rem;
  }

  .scholarship-copy,
  .scholarship-poster {
    display: grid;
    gap: 0.85rem;
  }

  .scholarship-chip {
    display: inline-flex;
    width: fit-content;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #1f5e40;
    background: rgba(206, 242, 216, 0.9);
    border: 1px solid rgba(74, 171, 108, 0.4);
    font-weight: 700;
  }

  .scholarship-pill-row span {
    color: #1f5e40;
    border-color: rgba(74, 171, 108, 0.4);
    background: rgba(236, 250, 240, 0.92);
  }

  .scholarship-poster {
    border: 1px solid rgba(85, 175, 114, 0.35);
    background: linear-gradient(160deg, rgba(242, 252, 246, 0.95), rgba(223, 244, 231, 0.82));
  }

  .poster-flyer {
    width: 100%;
    border-radius: 14px;
    border: 1px solid rgba(81, 169, 111, 0.35);
    display: block;
    object-fit: cover;
    max-height: 430px;
  }

  .scholarship-poster.flyer-missing .poster-head {
    margin-top: 0;
  }

  .poster-head {
    border-radius: 14px;
    padding: 0.85rem;
    background: linear-gradient(135deg, #12548c, #1a7a61);
    color: #ffffff;
  }

  .poster-kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.86);
  }

  .poster-head h3 {
    margin-top: 0.35rem;
    font-size: clamp(1.35rem, 2vw, 1.8rem);
  }

  .poster-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .poster-block {
    border-radius: 14px;
    padding: 0.8rem;
    border: 1px solid rgba(85, 175, 114, 0.3);
    background: rgba(255, 255, 255, 0.86);
  }

  .poster-block h4 {
    margin: 0;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #1f5e40;
  }

  .poster-block p {
    margin-top: 0.35rem;
    color: #2f5c43;
    font-size: 0.95rem;
  }

  .poster-highlight {
    background: linear-gradient(145deg, rgba(205, 242, 216, 0.92), rgba(235, 251, 241, 0.9));
  }

  /* Tagline on main image */
  .hero-mosaic-tag {
    position: absolute;
    bottom: 0.85rem;
    left: 0.9rem;
    z-index: 3;
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #ffffff;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
  }

  /* ── Bottom row ───────────────────────────────────── */
  .hero-mosaic-row {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 3px;
    background: #0d4a6b;
  }

  .hero-mosaic-thumb {
    overflow: hidden;
  }

  .hero-mosaic-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
    transition: transform 0.5s ease;
  }

  .hero-mosaic-thumb:hover img {
    transform: scale(1.06);
  }

  /* Centre stat block */
  .hero-mosaic-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.1rem;
    background: linear-gradient(145deg, #0f6e9b, #0a4270);
    color: #ffffff;
    min-width: 108px;
    gap: 0.15rem;
  }

  .hero-stat-num {
    font-size: 1.65rem;
    font-weight: 800;
    font-family: 'Barlow Condensed', sans-serif;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .hero-stat-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.85;
    text-align: center;
  }

  .hero-float {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    max-width: 220px;
    padding: 0.8rem;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(117, 190, 236, 0.35);
  }

  .hero-float h3,
  .hero-float p {
    margin: 0;
  }

  .hero-float p {
    margin-top: 0.35rem;
    color: var(--text-muted);
  }

  @media (max-width: 1024px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-visual,
    [data-hero-canvas] {
      min-height: 420px;
    }

    .scholarship-focus {
      grid-template-columns: 1fr;
    }

    .poster-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
